#!/usr/bin/env bash

UNAMEOUT="$(uname -s)"

# Verify operating system is supported...
case "${UNAMEOUT}" in
    Linux*)             MACHINE=linux;;
    Darwin*)            MACHINE=mac;;
    *)                  MACHINE="UNKNOWN"
esac

if [ "$MACHINE" == "UNKNOWN" ]; then
    echo "Unsupported operating system [$(uname -s)]. Laravel Podman supports macOS, Linux, and Windows (WSL2)." >&2

    exit 1
fi

# Determine if stdout is a terminal...
if test -t 1; then
    # Determine if colors are supported...
    ncolors=$(tput colors)

    if test -n "$ncolors" && test "$ncolors" -ge 8; then
        BOLD="$(tput bold)"
        YELLOW="$(tput setaf 3)"
        GREEN="$(tput setaf 2)"
        NC="$(tput sgr0)"
    fi
fi

# Function that prints the available commands...
function display_help {
    echo "Laravel Podman"
    echo
    echo "${YELLOW}Usage:${NC}" >&2
    echo "  lpod SERVICE COMMAND [options] [arguments]"
    echo
    echo "SERVICE is the name of a Podman Quadlet service (e.g. the application"
    echo "service, or a sibling service such as 'pgsql'). Unknown commands are"
    echo "passed through to the podman binary."
    echo
    echo "${YELLOW}Lifecycle Commands:${NC}"
    echo "  ${GREEN}lpod my-app up${NC}        Start the 'my-app' service"
    echo "  ${GREEN}lpod my-app down${NC}      Stop the 'my-app' service"
    echo "  ${GREEN}lpod my-app restart${NC}   Restart the 'my-app' service"
    echo "  ${GREEN}lpod my-app status${NC}    Show the status of the 'my-app' service"
    echo
    echo "${YELLOW}Artisan Commands:${NC}"
    echo "  ${GREEN}lpod my-app artisan ...${NC}          Run an Artisan command"
    echo "  ${GREEN}lpod my-app artisan queue:work${NC}"
    echo
    echo "${YELLOW}PHP Commands:${NC}"
    echo "  ${GREEN}lpod my-app php ...${NC}   Run a snippet of PHP code"
    echo "  ${GREEN}lpod my-app php -v${NC}"
    echo
    echo "${YELLOW}Composer Commands:${NC}"
    echo "  ${GREEN}lpod my-app composer ...${NC}                       Run a Composer command"
    echo "  ${GREEN}lpod my-app composer require laravel/sanctum${NC}"
    echo
    echo "${YELLOW}Node Commands:${NC}"
    echo "  ${GREEN}lpod my-app node ...${NC}         Run a Node command"
    echo "  ${GREEN}lpod my-app node --version${NC}"
    echo
    echo "${YELLOW}NPM Commands:${NC}"
    echo "  ${GREEN}lpod my-app npm ...${NC}        Run a npm command"
    echo "  ${GREEN}lpod my-app npx${NC}            Run a npx command"
    echo "  ${GREEN}lpod my-app npm run prod${NC}"
    echo
    echo "${YELLOW}PNPM Commands:${NC}"
    echo "  ${GREEN}lpod my-app pnpm ...${NC}        Run a pnpm command"
    echo "  ${GREEN}lpod my-app pnpx${NC}            Run a pnpx command"
    echo "  ${GREEN}lpod my-app pnpm run prod${NC}"
    echo
    echo "${YELLOW}Yarn Commands:${NC}"
    echo "  ${GREEN}lpod my-app yarn ...${NC}        Run a Yarn command"
    echo "  ${GREEN}lpod my-app yarn run prod${NC}"
    echo
    echo "${YELLOW}Bun Commands:${NC}"
    echo "  ${GREEN}lpod my-app bun ...${NC}        Run a bun command"
    echo "  ${GREEN}lpod my-app bunx${NC}           Run a bunx command"
    echo "  ${GREEN}lpod my-app bun run prod${NC}"
    echo
    echo "${YELLOW}Debugging:${NC}"
    echo "  ${GREEN}lpod my-app debug ...${NC}          Run an Artisan command in debug mode"
    echo "  ${GREEN}lpod my-app debug queue:work${NC}"
    echo
    echo "${YELLOW}Running Tests:${NC}"
    echo "  ${GREEN}lpod my-app test${NC}          Run the PHPUnit tests via the Artisan test command"
    echo "  ${GREEN}lpod my-app phpunit ...${NC}   Run PHPUnit"
    echo "  ${GREEN}lpod my-app pest ...${NC}      Run Pest"
    echo "  ${GREEN}lpod my-app pint ...${NC}      Run Pint"
    echo "  ${GREEN}lpod my-app dusk${NC}          Run the Dusk tests (Requires the laravel/dusk package)"
    echo "  ${GREEN}lpod my-app dusk:fails${NC}    Re-run previously failed Dusk tests (Requires the laravel/dusk package)"
    echo
    echo "${YELLOW}Container CLI:${NC}"
    echo "  ${GREEN}lpod my-app shell${NC}        Start a shell session within the service container"
    echo "  ${GREEN}lpod my-app bash${NC}         Alias for 'lpod my-app shell'"
    echo "  ${GREEN}lpod my-app root-shell${NC}   Start a root shell session within the service container"
    echo "  ${GREEN}lpod my-app root-bash${NC}    Alias for 'lpod my-app root-shell'"
    echo "  ${GREEN}lpod my-app tinker${NC}       Start a new Laravel Tinker session"
    echo
    echo "${YELLOW}Binaries:${NC}"
    echo "  ${GREEN}lpod my-app bin ...${NC}   Run Composer binary scripts from the vendor/bin directory"
    echo "  ${GREEN}lpod my-app run ...${NC}   Run a command within the service container"
    echo
    echo "${YELLOW}Other:${NC}"
    echo "  ${GREEN}lpod my-app open${NC}                     Open the application URL in your browser"
    echo "  ${GREEN}lpod my-app artisan podman:publish${NC}   Publish the Podman container runtime files"

    exit 1
}

# Show help when no service, or an explicit help flag, is given...
if [ $# -eq 0 ] || [ "$1" == "help" ] || [ "$1" == "-h" ] || [ "$1" == "-help" ] || [ "$1" == "--help" ]; then
    display_help
fi

SERVICE="$1"
shift

if [ $# -eq 0 ]; then
    echo "${BOLD}Missing command.${NC} Usage: lpod ${SERVICE} COMMAND [options] [arguments]" >&2

    exit 1
fi

# Source the ".env" file so Laravel's environment variables are available...
# shellcheck source=/dev/null
if [ -n "$APP_ENV" ] && [ -f ./.env."$APP_ENV" ]; then
  source ./.env."$APP_ENV";
elif [ -f ./.env ]; then
  source ./.env;
fi

# Define environment variables...
export APP_PORT=${APP_PORT:-80}
export APP_USER=${APP_USER:-"docker"}
export LPOD_DOCKER_BINARY=${LPOD_DOCKER_BINARY:-"podman"}

# AI agent environment variables to forward into containers...
AGENT_ENV_VARS=(
    AI_AGENT
    CLAUDECODE
    CLAUDE_CODE
    CLAUDE_CODE_IS_COWORK
    CURSOR_TRACE_ID
    CURSOR_AGENT
    GEMINI_CLI
    CODEX_SANDBOX
    CODEX_CI
    CODEX_THREAD_ID
    AUGMENT_AGENT
    OPENCODE_CLIENT
    OPENCODE
    AMP_CURRENT_THREAD_ID
    REPL_ID
    ANTIGRAVITY_AGENT
    COPILOT_MODEL
    COPILOT_ALLOW_ALL
    COPILOT_GITHUB_TOKEN
    COPILOT_CLI
    PI_CODING_AGENT
    KIRO_AGENT_PATH
)

function forward_agent_env() {
    for VAR in "${AGENT_ENV_VARS[@]}"; do
        if [ -n "${!VAR:-}" ]; then
            ARGS+=(-e "${VAR}=${!VAR}")
        fi
    done
}

# Use the system-wide systemd manager when running as root, otherwise the
# per-user manager backing rootless Quadlet services...
if [ "$(id -u)" -eq 0 ]; then
    SYSTEMCTL_CMD=(systemctl)
else
    SYSTEMCTL_CMD=(systemctl --user)
fi

# Quadlet installs a Podman container named "systemd-<unit>" for every
# "<unit>.service" it manages, to avoid clashing with unmanaged containers...
CONTAINER="systemd-${SERVICE}"

# Determine whether to allocate a pseudo-tty for "podman exec"...
if test -t 0 && test -t 1; then
    TTY_ARGS=(-it)
else
    TTY_ARGS=(-i)
fi

COMMAND="$1"
shift

ARGS=()

case "$COMMAND" in
    # Start, stop, restart, and inspect the Quadlet-managed systemd service...
    up)
        exec "${SYSTEMCTL_CMD[@]}" start "${SERVICE}.service"
        ;;

    down)
        exec "${SYSTEMCTL_CMD[@]}" stop "${SERVICE}.service"
        ;;

    restart)
        exec "${SYSTEMCTL_CMD[@]}" restart "${SERVICE}.service"
        ;;

    status)
        exec "${SYSTEMCTL_CMD[@]}" status "${SERVICE}.service"
        ;;

    # Proxy PHP commands to the "php" binary on the service container...
    php)
        ARGS+=(exec -u "$APP_USER" "${TTY_ARGS[@]}")
        forward_agent_env
        ARGS+=("$CONTAINER" php)
        ;;

    # Proxy vendor binary commands on the service container...
    bin)
        CMD="$1"
        shift
        ARGS+=(exec -u "$APP_USER" "${TTY_ARGS[@]}")
        forward_agent_env
        ARGS+=("$CONTAINER" "./vendor/bin/${CMD}")
        ;;

    # Proxy arbitrary commands on the service container...
    run)
        CMD="$1"
        shift
        ARGS+=(exec -u "$APP_USER" "${TTY_ARGS[@]}")
        forward_agent_env
        ARGS+=("$CONTAINER" "$CMD")
        ;;

    # Proxy Composer commands to the "composer" binary on the service container...
    composer)
        ARGS+=(exec -u "$APP_USER" "${TTY_ARGS[@]}")
        forward_agent_env
        ARGS+=("$CONTAINER" composer)
        ;;

    # Proxy Artisan commands to the "artisan" binary on the service container...
    artisan|art|a)
        ARGS+=(exec -u "$APP_USER" "${TTY_ARGS[@]}")
        forward_agent_env
        ARGS+=("$CONTAINER" php artisan)
        ;;

    # Proxy the "debug" command to "php artisan" on the service container with xdebug enabled...
    debug)
        ARGS+=(exec -u "$APP_USER" -e XDEBUG_TRIGGER=1 "${TTY_ARGS[@]}")
        forward_agent_env
        ARGS+=("$CONTAINER" php artisan)
        ;;

    # Proxy the "test" command to the "php artisan test" Artisan command...
    test)
        ARGS+=(exec -u "$APP_USER" "${TTY_ARGS[@]}")
        forward_agent_env
        ARGS+=("$CONTAINER" php artisan test)
        ;;

    # Proxy the "phpunit" command to "php vendor/bin/phpunit"...
    phpunit)
        ARGS+=(exec -u "$APP_USER" "${TTY_ARGS[@]}")
        forward_agent_env
        ARGS+=("$CONTAINER" php vendor/bin/phpunit)
        ;;

    # Proxy the "pest" command to "php vendor/bin/pest"...
    pest)
        ARGS+=(exec -u "$APP_USER" "${TTY_ARGS[@]}")
        forward_agent_env
        ARGS+=("$CONTAINER" php vendor/bin/pest)
        ;;

    # Proxy the "pint" command to "php vendor/bin/pint"...
    pint)
        ARGS+=(exec -u "$APP_USER" "${TTY_ARGS[@]}")
        forward_agent_env
        ARGS+=("$CONTAINER" php vendor/bin/pint)
        ;;

    # Proxy the "dusk" command to the "php artisan dusk" Artisan command...
    dusk)
        ARGS+=(exec -u "$APP_USER" -e "APP_URL=http://${CONTAINER}" -e "DUSK_DRIVER_URL=http://selenium:4444/wd/hub" "${TTY_ARGS[@]}")
        forward_agent_env
        ARGS+=("$CONTAINER" php artisan dusk)
        ;;

    # Proxy the "dusk:fails" command to the "php artisan dusk:fails" Artisan command...
    dusk:fails)
        ARGS+=(exec -u "$APP_USER" -e "APP_URL=http://${CONTAINER}" -e "DUSK_DRIVER_URL=http://selenium:4444/wd/hub" "${TTY_ARGS[@]}")
        forward_agent_env
        ARGS+=("$CONTAINER" php artisan dusk:fails)
        ;;

    # Initiate a Laravel Tinker session within the service container...
    tinker)
        ARGS+=(exec -u "$APP_USER" "${TTY_ARGS[@]}")
        forward_agent_env
        ARGS+=("$CONTAINER" php artisan tinker)
        ;;

    # Proxy Node commands to the "node" binary on the service container...
    node)
        ARGS+=(exec -u "$APP_USER" "${TTY_ARGS[@]}")
        forward_agent_env
        ARGS+=("$CONTAINER" node)
        ;;

    # Proxy NPM commands to the "npm" binary on the service container...
    npm)
        ARGS+=(exec -u "$APP_USER" "${TTY_ARGS[@]}")
        forward_agent_env
        ARGS+=("$CONTAINER" npm)
        ;;

    # Proxy NPX commands to the "npx" binary on the service container...
    npx)
        ARGS+=(exec -u "$APP_USER" "${TTY_ARGS[@]}")
        forward_agent_env
        ARGS+=("$CONTAINER" npx)
        ;;

    # Proxy PNPM commands to the "pnpm" binary on the service container...
    pnpm)
        ARGS+=(exec -u "$APP_USER" "${TTY_ARGS[@]}")
        forward_agent_env
        ARGS+=("$CONTAINER" pnpm)
        ;;

    # Proxy PNPX commands to the "pnpx" binary on the service container...
    pnpx)
        ARGS+=(exec -u "$APP_USER" "${TTY_ARGS[@]}")
        forward_agent_env
        ARGS+=("$CONTAINER" pnpx)
        ;;

    # Proxy Yarn commands to the "yarn" binary on the service container...
    yarn)
        ARGS+=(exec -u "$APP_USER" "${TTY_ARGS[@]}")
        forward_agent_env
        ARGS+=("$CONTAINER" yarn)
        ;;

    # Proxy Bun commands to the "bun" binary on the service container...
    bun)
        ARGS+=(exec -u "$APP_USER" "${TTY_ARGS[@]}")
        forward_agent_env
        ARGS+=("$CONTAINER" bun)
        ;;

    # Proxy Bun X commands to the "bunx" binary on the service container...
    bunx)
        ARGS+=(exec -u "$APP_USER" "${TTY_ARGS[@]}")
        forward_agent_env
        ARGS+=("$CONTAINER" bunx)
        ;;

    # Initiate a Bash shell within the service container...
    shell|bash)
        ARGS+=(exec -u "$APP_USER" "${TTY_ARGS[@]}")
        forward_agent_env
        ARGS+=("$CONTAINER" bash)
        ;;

    # Initiate a root user Bash shell within the service container...
    root-shell|root-bash)
        ARGS+=(exec -u root "${TTY_ARGS[@]}")
        forward_agent_env
        ARGS+=("$CONTAINER" bash)
        ;;

    # Open the application URL in the browser...
    open)
        if command -v open &>/dev/null; then
            OPEN="open"
        elif command -v xdg-open &>/dev/null; then
            OPEN="xdg-open"
        else
            echo "Neither open nor xdg-open is available. Exiting." >&2

            exit 1
        fi

        if [[ -n "$APP_PORT" && "$APP_PORT" != "80" ]]; then
            FULL_URL="${APP_URL}:${APP_PORT}"
        else
            FULL_URL="$APP_URL"
        fi

        exec "$OPEN" "$FULL_URL"
        ;;

    # Unknown commands are passed through to the podman binary...
    *)
        exec "${LPOD_DOCKER_BINARY}" "$COMMAND" "$@"
        ;;
esac

exec "${LPOD_DOCKER_BINARY}" "${ARGS[@]}" "$@"
