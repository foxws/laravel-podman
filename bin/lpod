#!/usr/bin/env bash

UNAMEOUT="$(uname -s)"

# Verify operating system is supported...
case "${UNAMEOUT}" in
    Linux*)             MACHINE=linux;;
    Darwin*)            MACHINE=mac;;
    *)                  MACHINE="UNKNOWN"
esac

if [ "$MACHINE" == "UNKNOWN" ]; then
    echo "Unsupported operating system [$(uname -s)]. Laravel Podman supports macOS, Linux, and Windows (WSL2)." >&2

    exit 1
fi

# Determine if stdout is a terminal...
if test -t 1; then
    # Determine if colors are supported...
    ncolors=$(tput colors)

    if test -n "$ncolors" && test "$ncolors" -ge 8; then
        BOLD="$(tput bold)"
        YELLOW="$(tput setaf 3)"
        GREEN="$(tput setaf 2)"
        NC="$(tput sgr0)"
    fi
fi

# Function that prints the available commands...
function display_help {
    echo "Laravel Podman"
    echo
    echo "${YELLOW}Usage:${NC}" >&2
    echo "  lpod COMMAND [options] [arguments]"
    echo
    echo "Unknown commands are passed to the podman binary."
    echo
    echo "${YELLOW}Podman Commands:${NC}"
    echo "  ${GREEN}lpod up${NC}        Start the application"
    echo "  ${GREEN}lpod up -d${NC}     Start the application in the background"
    echo "  ${GREEN}lpod stop${NC}      Stop the application"
    echo "  ${GREEN}lpod restart${NC}   Restart the application"
    echo "  ${GREEN}lpod ps${NC}        Display the status of all containers"
    echo
    echo "${YELLOW}Artisan Commands:${NC}"
    echo "  ${GREEN}lpod artisan ...${NC}          Run an Artisan command"
    echo "  ${GREEN}lpod artisan queue:work${NC}"
    echo
    echo "${YELLOW}PHP Commands:${NC}"
    echo "  ${GREEN}lpod php ...${NC}   Run a snippet of PHP code"
    echo "  ${GREEN}lpod php -v${NC}"
    echo
    echo "${YELLOW}Composer Commands:${NC}"
    echo "  ${GREEN}lpod composer ...${NC}                       Run a Composer command"
    echo "  ${GREEN}lpod composer require laravel/sanctum${NC}"
    echo
    echo "${YELLOW}Node Commands:${NC}"
    echo "  ${GREEN}lpod node ...${NC}         Run a Node command"
    echo "  ${GREEN}lpod node --version${NC}"
    echo
    echo "${YELLOW}NPM Commands:${NC}"
    echo "  ${GREEN}lpod npm ...${NC}        Run a npm command"
    echo "  ${GREEN}lpod npx${NC}            Run a npx command"
    echo "  ${GREEN}lpod npm run prod${NC}"
    echo
    echo "${YELLOW}PNPM Commands:${NC}"
    echo "  ${GREEN}lpod pnpm ...${NC}        Run a pnpm command"
    echo "  ${GREEN}lpod pnpx${NC}            Run a pnpx command"
    echo "  ${GREEN}lpod pnpm run prod${NC}"
    echo
    echo "${YELLOW}Yarn Commands:${NC}"
    echo "  ${GREEN}lpod yarn ...${NC}        Run a Yarn command"
    echo "  ${GREEN}lpod yarn run prod${NC}"
    echo
    echo "${YELLOW}Bun Commands:${NC}"
    echo "  ${GREEN}lpod bun ...${NC}        Run a bun command"
    echo "  ${GREEN}lpod bunx${NC}           Run a bunx command"
    echo "  ${GREEN}lpod bun run prod${NC}"
    echo
    echo "${YELLOW}Database Commands:${NC}"
    echo "  ${GREEN}lpod mysql${NC}     Start a MySQL CLI session within the 'mysql' container"
    echo "  ${GREEN}lpod mariadb${NC}   Start a MySQL CLI session within the 'mariadb' container"
    echo "  ${GREEN}lpod psql${NC}      Start a PostgreSQL CLI session within the 'pgsql' container"
    echo "  ${GREEN}lpod mongodb${NC}   Start a Mongo Shell session within the 'mongodb' container"
    echo "  ${GREEN}lpod redis${NC}     Start a Redis CLI session within the 'redis' container"
    echo "  ${GREEN}lpod valkey${NC}    Start a Valkey CLI session within the 'valkey' container"
    echo
    echo "${YELLOW}Debugging:${NC}"
    echo "  ${GREEN}lpod debug ...${NC}          Run an Artisan command in debug mode"
    echo "  ${GREEN}lpod debug queue:work${NC}"
    echo
    echo "${YELLOW}Running Tests:${NC}"
    echo "  ${GREEN}lpod test${NC}          Run the PHPUnit tests via the Artisan test command"
    echo "  ${GREEN}lpod phpunit ...${NC}   Run PHPUnit"
    echo "  ${GREEN}lpod pest ...${NC}      Run Pest"
    echo "  ${GREEN}lpod pint ...${NC}      Run Pint"
    echo "  ${GREEN}lpod dusk${NC}          Run the Dusk tests (Requires the laravel/dusk package)"
    echo "  ${GREEN}lpod dusk:fails${NC}    Re-run previously failed Dusk tests (Requires the laravel/dusk package)"
    echo
    echo "${YELLOW}Container CLI:${NC}"
    echo "  ${GREEN}lpod shell${NC}        Start a shell session within the application container"
    echo "  ${GREEN}lpod bash${NC}         Alias for 'lpod shell'"
    echo "  ${GREEN}lpod root-shell${NC}   Start a root shell session within the application container"
    echo "  ${GREEN}lpod root-bash${NC}    Alias for 'lpod root-shell'"
    echo "  ${GREEN}lpod tinker${NC}       Start a new Laravel Tinker session"
    echo
    echo "${YELLOW}Quadlet Containers:${NC}"
    echo "  ${GREEN}lpod --container queue${NC}          Shell into the 'systemd-queue' Quadlet container"
    echo "  ${GREEN}lpod --container queue ps aux${NC}   Run a command inside the 'systemd-queue' container"
    echo "  ${GREEN}lpod --container=queue${NC}          Same as above, using the '=' form"
    echo "  ${GREEN}lpod --container queue --no-prefix${NC}   Target the container 'queue' without the 'systemd-' prefix"
    echo
    echo "${YELLOW}Sharing:${NC}"
    echo "  ${GREEN}lpod share${NC}   Share the application publicly via a temporary URL"
    echo "  ${GREEN}lpod open${NC}    Open the site in your browser"
    echo
    echo "${YELLOW}Binaries:${NC}"
    echo "  ${GREEN}lpod bin ...${NC}   Run Composer binary scripts from the vendor/bin directory"
    echo "  ${GREEN}lpod run ...${NC}   Run a command within the application container"
    echo
    echo "${YELLOW}Customization:${NC}"
    echo "  ${GREEN}lpod artisan lpod:publish${NC}   Publish the Podman configuration files"
    echo "  ${GREEN}lpod build --no-cache${NC}       Rebuild all of the Podman containers"

    exit 1
}

# Proxy the "help" command...
if [ $# -gt 0 ]; then
    if [ "$1" == "help" ] || [ "$1" == "-h" ] || [ "$1" == "-help" ] || [ "$1" == "--help" ]; then
        display_help
    fi
else
    display_help
fi

# Source the ".env" file so Laravel's environment variables are available...
# shellcheck source=/dev/null
if [ -n "$APP_ENV" ] && [ -f ./.env."$APP_ENV" ]; then
  source ./.env."$APP_ENV";
elif [ -f ./.env ]; then
  source ./.env;
fi

# Define environment variables...
export APP_PORT=${APP_PORT:-80}
export APP_SERVICE=${APP_SERVICE:-"app"}
export APP_USER=${APP_USER:-"lpod"}
export DB_PORT=${DB_PORT:-3306}
export WWWUSER=${WWWUSER:-$UID}
export WWWGROUP=${WWWGROUP:-$(id -g)}

export LPOD_FILES=${LPOD_FILES:-""}
export LPOD_SHARE_DASHBOARD=${LPOD_SHARE_DASHBOARD:-4040}
export LPOD_SHARE_SERVER_HOST=${LPOD_SHARE_SERVER_HOST:-"laravel-lpod.site"}
export LPOD_SHARE_SERVER_PORT=${LPOD_SHARE_SERVER_PORT:-8080}
export LPOD_SHARE_SUBDOMAIN=${LPOD_SHARE_SUBDOMAIN:-""}
export LPOD_SHARE_DOMAIN=${LPOD_SHARE_DOMAIN:-"$LPOD_SHARE_SERVER_HOST"}
export LPOD_SHARE_SERVER=${LPOD_SHARE_SERVER:-""}
export LPOD_DOCKER_BINARY=${LPOD_DOCKER_BINARY:-"podman"}

# Function that outputs Podman is not running...
function lpod_is_not_running {
    echo "${BOLD}Podman is not running.${NC}" >&2
    echo "" >&2
    echo "${BOLD}You may Podman using the following commands:${NC} './vendor/bin/lpod up' or './vendor/bin/lpod up -d'" >&2

    exit 1
}

# AI agent environment variables to forward into containers...
AGENT_ENV_VARS=(
    AI_AGENT
    CLAUDECODE
    CLAUDE_CODE
    CLAUDE_CODE_IS_COWORK
    CURSOR_TRACE_ID
    CURSOR_AGENT
    GEMINI_CLI
    CODEX_SANDBOX
    CODEX_CI
    CODEX_THREAD_ID
    AUGMENT_AGENT
    OPENCODE_CLIENT
    OPENCODE
    AMP_CURRENT_THREAD_ID
    REPL_ID
    ANTIGRAVITY_AGENT
    COPILOT_MODEL
    COPILOT_ALLOW_ALL
    COPILOT_GITHUB_TOKEN
    COPILOT_CLI
    PI_CODING_AGENT
    KIRO_AGENT_PATH
)

function forward_agent_env() {
    for VAR in "${AGENT_ENV_VARS[@]}"; do
        if [ -n "${!VAR:-}" ]; then
            ARGS+=(-e "${VAR}=${!VAR}")
        fi
    done
}

# Proxy the "--container" flag to "podman exec" against a Quadlet-managed container...
CONTAINER=""
CONTAINER_PREFIX="systemd-"

while [ $# -gt 0 ]; do
    case "$1" in
        --container=*)
            CONTAINER="${1#*=}"
            shift 1
            ;;
        --container)
            CONTAINER="$2"
            shift 2
            ;;
        --no-prefix)
            CONTAINER_PREFIX=""
            shift 1
            ;;
        *)
            break
            ;;
    esac
done

if [ -n "$CONTAINER" ]; then
    [ $# -eq 0 ] && set -- bash

    ARGS=(exec)

    if test -t 0 && test -t 1; then
        ARGS+=(-it)
    else
        ARGS+=(-i)
    fi

    forward_agent_env
    ARGS+=("${CONTAINER_PREFIX}${CONTAINER}")

    exec "${LPOD_DOCKER_BINARY}" "${ARGS[@]}" "$@"
fi

# Define Docker Compose command prefix...
if ${LPOD_DOCKER_BINARY} compose &> /dev/null; then
    COMPOSE_CMD=(${LPOD_DOCKER_BINARY} compose)
else
    COMPOSE_CMD=(${LPOD_DOCKER_BINARY}-compose)
fi

if [ -n "$LPOD_FILES" ]; then
    # Convert LPOD_FILES to an array...
    IFS=':' read -ra LPOD_FILES <<< "$LPOD_FILES"

    for FILE in "${LPOD_FILES[@]}"; do
        if [ -f "$FILE" ]; then
            COMPOSE_CMD+=(-f "$FILE")
        else
            echo "${BOLD}Unable to find Docker Compose file: '${FILE}'${NC}" >&2

            exit 1
        fi
    done
fi

EXEC="yes"

if [ -z "$LPOD_SKIP_CHECKS" ]; then
    # Ensure that Docker is running...
    if ! ${LPOD_DOCKER_BINARY} info > /dev/null 2>&1; then
        echo "${BOLD}Docker or Podman is not running.${NC}" >&2

        exit 1
    fi

    # Determine if Podman is currently up...
    if "${COMPOSE_CMD[@]}" ps "$APP_SERVICE" 2>&1 | grep 'Exit\|exited'; then
        echo "${BOLD}Shutting down old Podman processes...${NC}" >&2

        "${COMPOSE_CMD[@]}" down > /dev/null 2>&1

        EXEC="no"
    elif [ -z "$("${COMPOSE_CMD[@]}" ps -q)" ]; then
        EXEC="no"
    fi
fi

ARGS=()

# Proxy PHP commands to the "php" binary on the application container...
if [ "$1" == "php" ]; then
    shift 1

    if [ "$EXEC" == "yes" ]; then
        ARGS+=(exec -u "$APP_USER")
        [ ! -t 0 ] && ARGS+=(-T)
        forward_agent_env
        ARGS+=("$APP_SERVICE" "php")
    else
        lpod_is_not_running
    fi

# Proxy vendor binary commands on the application container...
elif [ "$1" == "bin" ]; then
    shift 1

    if [ "$EXEC" == "yes" ]; then
        CMD=$1
        shift 1
        ARGS+=(exec -u "$APP_USER")
        [ ! -t 0 ] && ARGS+=(-T)
        forward_agent_env
        ARGS+=("$APP_SERVICE" ./vendor/bin/"$CMD")
    else
        lpod_is_not_running
    fi

# Proxy commands on the application container...
elif [ "$1" == "run" ]; then
    shift 1

    if [ "$EXEC" == "yes" ]; then
        CMD=$1
        shift 1
        ARGS+=(exec -u "$APP_USER")
        [ ! -t 0 ] && ARGS+=(-T)
        forward_agent_env
        ARGS+=("$APP_SERVICE" "$CMD")
    else
        lpod_is_not_running
    fi

# Proxy podman commands to the podman binary on the application container...
elif [ "$1" == "podman" ]; then
    shift 1

    if [ "$EXEC" == "yes" ]; then
        ARGS+=(exec -u "$APP_USER")
        [ ! -t 0 ] && ARGS+=(-T)
        forward_agent_env
        ARGS+=("$APP_SERVICE" "${COMPOSE_CMD[@]}")
    else
        lpod_is_not_running
    fi

# Proxy Composer commands to the "composer" binary on the application container...
elif [ "$1" == "composer" ]; then
    shift 1

    if [ "$EXEC" == "yes" ]; then
        ARGS+=(exec -u "$APP_USER")
        [ ! -t 0 ] && ARGS+=(-T)
        forward_agent_env
        ARGS+=("$APP_SERVICE" "composer")
    else
        lpod_is_not_running
    fi

# Proxy Artisan commands to the "artisan" binary on the application container...
elif [ "$1" == "artisan" ] || [ "$1" == "art" ] || [ "$1" == "a" ]; then
    shift 1

    if [ "$EXEC" == "yes" ]; then
        ARGS+=(exec -u "$APP_USER")
        [ ! -t 0 ] && ARGS+=(-T)
        forward_agent_env
        ARGS+=("$APP_SERVICE" php artisan)
    else
        lpod_is_not_running
    fi

# Proxy the "debug" command to the "php artisan" binary on the application container with xdebug enabled...
elif [ "$1" == "debug" ]; then
    shift 1

    if [ "$EXEC" == "yes" ]; then
        ARGS+=(exec -u "$APP_USER" -e XDEBUG_TRIGGER=1)
        [ ! -t 0 ] && ARGS+=(-T)
        forward_agent_env
        ARGS+=("$APP_SERVICE" php artisan)
    else
        lpod_is_not_running
    fi

# Proxy the "test" command to the "php artisan test" Artisan command...
elif [ "$1" == "test" ]; then
    shift 1

    if [ "$EXEC" == "yes" ]; then
        ARGS+=(exec -u "$APP_USER")
        [ ! -t 0 ] && ARGS+=(-T)
        forward_agent_env
        ARGS+=("$APP_SERVICE" php artisan test)
    else
        lpod_is_not_running
    fi

# Proxy the "phpunit" command to "php vendor/bin/phpunit"...
elif [ "$1" == "phpunit" ]; then
    shift 1

    if [ "$EXEC" == "yes" ]; then
        ARGS+=(exec -u "$APP_USER")
        [ ! -t 0 ] && ARGS+=(-T)
        forward_agent_env
        ARGS+=("$APP_SERVICE" php vendor/bin/phpunit)
    else
        lpod_is_not_running
    fi

# Proxy the "pest" command to "php vendor/bin/pest"...
elif [ "$1" == "pest" ]; then
    shift 1

    if [ "$EXEC" == "yes" ]; then
        ARGS+=(exec -u "$APP_USER")
        [ ! -t 0 ] && ARGS+=(-T)
        forward_agent_env
        ARGS+=("$APP_SERVICE" php vendor/bin/pest)
    else
        lpod_is_not_running
    fi

# Proxy the "pint" command to "php vendor/bin/pint"...
elif [ "$1" == "pint" ]; then
    shift 1

    if [ "$EXEC" == "yes" ]; then
        ARGS+=(exec -u "$APP_USER")
        [ ! -t 0 ] && ARGS+=(-T)
        forward_agent_env
        ARGS+=("$APP_SERVICE" php vendor/bin/pint)
    else
        lpod_is_not_running
    fi

# Proxy the "dusk" command to the "php artisan dusk" Artisan command...
elif [ "$1" == "dusk" ]; then
    shift 1

    if [ "$EXEC" == "yes" ]; then
        ARGS+=(exec -u "$APP_USER")
        [ ! -t 0 ] && ARGS+=(-T)
        forward_agent_env
        ARGS+=(-e "APP_URL=http://${APP_SERVICE}")
        ARGS+=(-e "DUSK_DRIVER_URL=http://selenium:4444/wd/hub")
        ARGS+=("$APP_SERVICE" php artisan dusk)
    else
        lpod_is_not_running
    fi

# Proxy the "dusk:fails" command to the "php artisan dusk:fails" Artisan command...
elif [ "$1" == "dusk:fails" ]; then
    shift 1

    if [ "$EXEC" == "yes" ]; then
        ARGS+=(exec -u "$APP_USER")
        [ ! -t 0 ] && ARGS+=(-T)
        forward_agent_env
        ARGS+=(-e "APP_URL=http://${APP_SERVICE}")
        ARGS+=(-e "DUSK_DRIVER_URL=http://selenium:4444/wd/hub")
        ARGS+=("$APP_SERVICE" php artisan dusk:fails)
    else
        lpod_is_not_running
    fi

# Initiate a Laravel Tinker session within the application container...
elif [ "$1" == "tinker" ]; then
    shift 1

    if [ "$EXEC" == "yes" ]; then
        ARGS+=(exec -u "$APP_USER")
        [ ! -t 0 ] && ARGS+=(-T)
        forward_agent_env
        ARGS+=("$APP_SERVICE" php artisan tinker)
    else
        lpod_is_not_running
    fi

# Proxy Node commands to the "node" binary on the application container...
elif [ "$1" == "node" ]; then
    shift 1

    if [ "$EXEC" == "yes" ]; then
        ARGS+=(exec -u "$APP_USER")
        [ ! -t 0 ] && ARGS+=(-T)
        forward_agent_env
        ARGS+=("$APP_SERVICE" node)
    else
        lpod_is_not_running
    fi

# Proxy NPM commands to the "npm" binary on the application container...
elif [ "$1" == "npm" ]; then
    shift 1

    if [ "$EXEC" == "yes" ]; then
        ARGS+=(exec -u "$APP_USER")
        [ ! -t 0 ] && ARGS+=(-T)
        forward_agent_env
        ARGS+=("$APP_SERVICE" npm)
    else
        lpod_is_not_running
    fi

# Proxy NPX commands to the "npx" binary on the application container...
elif [ "$1" == "npx" ]; then
    shift 1

    if [ "$EXEC" == "yes" ]; then
        ARGS+=(exec -u "$APP_USER")
        [ ! -t 0 ] && ARGS+=(-T)
        forward_agent_env
        ARGS+=("$APP_SERVICE" npx)
    else
        lpod_is_not_running
    fi

# Proxy PNPM commands to the "pnpm" binary on the application container...
elif [ "$1" == "pnpm" ]; then
    shift 1

    if [ "$EXEC" == "yes" ]; then
        ARGS+=(exec -u "$APP_USER")
        [ ! -t 0 ] && ARGS+=(-T)
        forward_agent_env
        ARGS+=("$APP_SERVICE" pnpm)
    else
        lpod_is_not_running
    fi

# Proxy PNPX commands to the "pnpx" binary on the application container...
elif [ "$1" == "pnpx" ]; then
    shift 1

    if [ "$EXEC" == "yes" ]; then
        ARGS+=(exec -u "$APP_USER")
        [ ! -t 0 ] && ARGS+=(-T)
        forward_agent_env
        ARGS+=("$APP_SERVICE" pnpx)
    else
        lpod_is_not_running
    fi

# Proxy Yarn commands to the "yarn" binary on the application container...
elif [ "$1" == "yarn" ]; then
    shift 1

    if [ "$EXEC" == "yes" ]; then
        ARGS+=(exec -u "$APP_USER")
        [ ! -t 0 ] && ARGS+=(-T)
        forward_agent_env
        ARGS+=("$APP_SERVICE" yarn)
    else
        lpod_is_not_running
    fi

# Proxy Bun commands to the "bun" binary on the application container...
elif [ "$1" == "bun" ]; then
    shift 1

    if [ "$EXEC" == "yes" ]; then
        ARGS+=(exec -u "$APP_USER")
        [ ! -t 0 ] && ARGS+=(-T)
        forward_agent_env
        ARGS+=("$APP_SERVICE" bun)
    else
        lpod_is_not_running
    fi

# Proxy Bun X commands to the "bunx" binary on the application container...
elif [ "$1" == "bunx" ]; then
    shift 1

    if [ "$EXEC" == "yes" ]; then
        ARGS+=(exec -u "$APP_USER")
        [ ! -t 0 ] && ARGS+=(-T)
        forward_agent_env
        ARGS+=("$APP_SERVICE" bunx)
    else
        lpod_is_not_running
    fi

# Initiate a MySQL CLI terminal session within the "mysql" container...
elif [ "$1" == "mysql" ]; then
    shift 1

    if [ "$EXEC" == "yes" ]; then
        ARGS+=(exec)
        [ ! -t 0 ] && ARGS+=(-T)
        ARGS+=(mysql bash -c)
        ARGS+=("MYSQL_PWD=\${MYSQL_PASSWORD} mysql -u \${MYSQL_USER} \${MYSQL_DATABASE} \${MYSQL_EXTRA_OPTIONS}")
    else
        lpod_is_not_running
    fi

# Initiate a MySQL CLI terminal session within the "mariadb" container...
elif [ "$1" == "mariadb" ]; then
    shift 1

    if [ "$EXEC" == "yes" ]; then
        ARGS+=(exec)
        [ ! -t 0 ] && ARGS+=(-T)
        ARGS+=(mariadb bash -c)
        ARGS+=("MYSQL_PWD=\${MYSQL_PASSWORD} mariadb -u \${MYSQL_USER} \${MYSQL_DATABASE}")
    else
        lpod_is_not_running
    fi

# Initiate a PostgreSQL CLI terminal session within the "pgsql" container...
elif [ "$1" == "psql" ]; then
    shift 1

    if [ "$EXEC" == "yes" ]; then
        ARGS+=(exec)
        [ ! -t 0 ] && ARGS+=(-T)
        ARGS+=(pgsql bash -c)
        ARGS+=("PGPASSWORD=\${PGPASSWORD} psql -U \${POSTGRES_USER} \${POSTGRES_DB}")
    else
        lpod_is_not_running
    fi

# Initiate a Bash shell within the application container...
elif [ "$1" == "shell" ] || [ "$1" == "bash" ]; then
    shift 1

    if [ "$EXEC" == "yes" ]; then
        ARGS+=(exec -u "$APP_USER")
        [ ! -t 0 ] && ARGS+=(-T)
        forward_agent_env
        ARGS+=("$APP_SERVICE" bash)
    else
        lpod_is_not_running
    fi

# Initiate a root user Bash shell within the application container...
elif [ "$1" == "root-shell" ] || [ "$1" == "root-bash" ]; then
    shift 1

    if [ "$EXEC" == "yes" ]; then
        ARGS+=(exec -u root)
        [ ! -t 0 ] && ARGS+=(-T)
        forward_agent_env
        ARGS+=("$APP_SERVICE" bash)
    else
        lpod_is_not_running
    fi

# Initiate a MongoDB Shell within the "mongodb" container...
elif [ "$1" == "mongodb" ]; then
    shift 1

    if [ "$EXEC" == "yes" ]; then
        ARGS+=(exec)
        [ ! -t 0 ] && ARGS+=(-T)
        ARGS+=(mongodb mongosh --port "${FORWARD_MONGODB_PORT:-27017}" --username "$MONGODB_USERNAME" --password "$MONGODB_PASSWORD" --authenticationDatabase admin)
    else
        lpod_is_not_running
    fi

# Initiate a Redis CLI terminal session within the "redis" container...
elif [ "$1" == "redis" ]; then
    shift 1

    if [ "$EXEC" == "yes" ]; then
        ARGS+=(exec)
        [ ! -t 0 ] && ARGS+=(-T)
        ARGS+=(redis redis-cli)
    else
        lpod_is_not_running
    fi

# Initiate a Valkey CLI terminal session within the "valkey" container...
elif [ "$1" == "valkey" ]; then
    shift 1

    if [ "$EXEC" == "yes" ]; then
        ARGS+=(exec)
        [ ! -t 0 ] && ARGS+=(-T)
        ARGS+=(valkey valkey-cli)
    else
        lpod_is_not_running
    fi

# Share the site...
elif [ "$1" == "share" ]; then
    shift 1

    if [ "$EXEC" == "yes" ]; then
        ${LPOD_DOCKER_BINARY} run --init --rm --add-host=host.docker.internal:host-gateway -p "$LPOD_SHARE_DASHBOARD":4040 -t beyondcodegmbh/expose-server:latest share http://host.docker.internal:"$APP_PORT" \
            --server-host="$LPOD_SHARE_SERVER_HOST" \
            --server-port="$LPOD_SHARE_SERVER_PORT" \
            --auth="$LPOD_SHARE_TOKEN" \
            --server="$LPOD_SHARE_SERVER" \
            --subdomain="$LPOD_SHARE_SUBDOMAIN" \
            --domain="$LPOD_SHARE_DOMAIN" \
            "$@"

        exit
    else
        lpod_is_not_running
    fi

# Open the site...
elif [ "$1" == "open" ]; then
    shift 1

    if command -v open &>/dev/null; then
        OPEN="open"
    elif command -v xdg-open &>/dev/null; then
        OPEN="xdg-open"
    else
        echo "Neither open nor xdg-open is available. Exiting."
        exit 1
    fi

    if [ "$EXEC" == "yes" ]; then

        if [[ -n "$APP_PORT" && "$APP_PORT" != "80" ]]; then
            FULL_URL="${APP_URL}:${APP_PORT}"
        else
            FULL_URL="$APP_URL"
        fi

        $OPEN "$FULL_URL"

        exit
    else
        lpod_is_not_running
    fi
fi

# Run Docker Compose with the defined arguments...
"${COMPOSE_CMD[@]}" "${ARGS[@]}" "$@"
