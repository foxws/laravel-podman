#!/usr/bin/env bash

set -euo pipefail

if [ $# -eq 0 ]; then
    echo "Usage: lpod secrets SERVICE [podman secret create flags...]" >&2

    exit 1
fi

SERVICE="$1"
shift
EXTRA_ARGS=("$@")

PODMAN="${LPOD_PODMAN_BINARY:-podman}"
UNIT="${SERVICE%.container}.container"

# Reads the "Secret=" directives straight from the installed unit, so it
# works off whatever "lpod install" actually installed rather than a rendered
# ".quadlets" file that may no longer exist on disk...
if ! CONTENTS="$("$PODMAN" quadlet print "$UNIT" 2>&1)"; then
    echo "${CONTENTS}" >&2
    echo "Could not print the \"${UNIT}\" quadlet. Run \"lpod install\" first." >&2

    exit 1
fi

# Parse every "Secret=name,type=...,target=..." directive, grouping targets
# by secret name (the same secret can be needed under several env var/mount
# names, e.g. a database password used as both POSTGRES_PASSWORD and
# PGPASSWORD)...
declare -A SECRET_TYPE
declare -A SECRET_TARGETS

while IFS= read -r LINE; do
    case "$LINE" in
        Secret=*) ;;
        *) continue ;;
    esac

    IFS=',' read -ra PARTS <<< "${LINE#Secret=}"
    NAME="${PARTS[0]}"
    TYPE="mount"
    TARGET="$NAME"

    for PART in "${PARTS[@]:1}"; do
        case "$PART" in
            type=*) TYPE="${PART#type=}" ;;
            target=*) TARGET="${PART#target=}" ;;
        esac
    done

    SECRET_TYPE["$NAME"]="$TYPE"

    if [ -n "${SECRET_TARGETS[$NAME]:-}" ]; then
        SECRET_TARGETS["$NAME"]="${SECRET_TARGETS[$NAME]}, ${TARGET}"
    else
        SECRET_TARGETS["$NAME"]="$TARGET"
    fi
done <<< "$CONTENTS"

if [ ${#SECRET_TYPE[@]} -eq 0 ]; then
    echo "No secrets found in ${UNIT}."

    exit 0
fi

for NAME in "${!SECRET_TYPE[@]}"; do
    if [ "${SECRET_TYPE[$NAME]}" = "mount" ]; then
        read -rp "Enter the file path for ${NAME} (${SECRET_TARGETS[$NAME]}) [.env]: " PATH_INPUT
        PATH_INPUT="${PATH_INPUT:-.env}"

        if [ ! -f "$PATH_INPUT" ]; then
            echo "The file ${PATH_INPUT} does not exist." >&2

            exit 1
        fi

        "$PODMAN" secret create "$NAME" - "${EXTRA_ARGS[@]}" < "$PATH_INPUT"
    else
        read -rsp "Enter the value for ${NAME} (${SECRET_TARGETS[$NAME]}): " VALUE
        echo

        printf '%s' "$VALUE" | "$PODMAN" secret create "$NAME" - "${EXTRA_ARGS[@]}"
    fi

    echo "Secret ${NAME} set."
done
