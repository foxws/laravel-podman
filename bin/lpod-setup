#!/usr/bin/env bash

set -euo pipefail

UNAMEOUT="$(uname -s)"

# Verify operating system is supported...
if [ "$UNAMEOUT" != "Linux" ]; then
    echo "Unsupported operating system [$(uname -s)]. Laravel Podman requires Linux with systemd; macOS and Windows, including WSL, are not supported." >&2

    exit 1
fi

if ! command -v podman >/dev/null 2>&1; then
    echo "The podman binary is required on the host to render Quadlet units inside a container." >&2

    exit 1
fi

# Define environment variables...
PHP_IMAGE=${LPOD_SETUP_PHP_IMAGE:-"docker.io/library/php:8.5-cli"}
PUBLISH_PATH=${LPOD_PUBLISH_PATH:-"podman"}

# Render every requested preset's ".quadlets"/runtime files into
# "$PUBLISH_PATH/{preset}", running as the host user so nothing ends up
# owned by root. This only renders — it doesn't install anything, since
# that's "lpod install"'s job once the podman binary (and this script) is
# available on the host...
echo "Rendering Quadlet units using the '${PHP_IMAGE}' image..."

podman run --rm --userns=keep-id -u "$(id -u):$(id -g)" \
    -e PODMAN_WORKING_PATH="$PWD" \
    -v "$PWD":/var/www/html:Z -w /var/www/html "$PHP_IMAGE" \
    php artisan podman:setup "$@"

shopt -s nullglob
QUADLET_FILES=("${PUBLISH_PATH}"/*/*.quadlets)
shopt -u nullglob

if [ ${#QUADLET_FILES[@]} -eq 0 ]; then
    echo "No rendered Quadlet units found in '${PUBLISH_PATH}'." >&2

    exit 1
fi

echo
echo "Rendered. Install each service with lpod, e.g.:"
echo

for FILE in "${QUADLET_FILES[@]}"; do
    echo "  lpod install ${FILE#"${PUBLISH_PATH}"/} --replace"
done
