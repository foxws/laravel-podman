#!/usr/bin/env bash

set -euo pipefail

UNAMEOUT="$(uname -s)"

# Verify operating system is supported...
if [ "$UNAMEOUT" != "Linux" ]; then
    echo "Unsupported operating system [$(uname -s)]. Laravel Podman requires Linux with systemd; macOS and Windows, including WSL, are not supported." >&2

    exit 1
fi

if ! command -v podman >/dev/null 2>&1; then
    echo "The podman binary is required on the host to render Quadlet units inside a container." >&2

    exit 1
fi

# Define environment variables...
PHP_IMAGE=${LPOD_SETUP_PHP_IMAGE:-"docker.io/library/php:8.5-cli"}
PUBLISH_PATH=${LPOD_PUBLISH_PATH:-"podman"}

# "--install"/"--secrets" are consumed here, not forwarded to "podman:setup"
# (which doesn't know them) — everything else in "$@" is passed through
# untouched. "--secrets" implies "--install", since secrets can only be read
# off an installed unit...
INSTALL=0
SECRETS=0
ARTISAN_ARGS=()

for ARG in "$@"; do
    case "$ARG" in
        --install) INSTALL=1 ;;
        --secrets) INSTALL=1; SECRETS=1 ;;
        *) ARTISAN_ARGS+=("$ARG") ;;
    esac
done

LPOD_BINARY="${LPOD_BINARY:-lpod}"

# Fail fast, before rendering/installing anything, if "--secrets" was
# requested but the "lpod" binary it shells out to isn't on PATH...
if [ "$SECRETS" -eq 1 ] && ! command -v "$LPOD_BINARY" >/dev/null 2>&1; then
    echo "The '${LPOD_BINARY}' binary is required to set secrets with --secrets. Install it from https://github.com/foxws/lpod, or point LPOD_BINARY at it." >&2

    exit 1
fi

# Render every requested preset's ".quadlets"/runtime files into
# "$PUBLISH_PATH/{preset}", running as the host user so nothing ends up
# owned by root. This only renders — it doesn't install anything unless
# "--install" is passed, since that's normally "lpod install"'s job once the
# podman binary (and this script) is available on the host...
echo "Rendering Quadlet units using the '${PHP_IMAGE}' image..."

podman run --rm --userns=keep-id -u "$(id -u):$(id -g)" \
    -e PODMAN_WORKING_PATH="$PWD" \
    -v "$PWD":/var/www/html:Z -w /var/www/html "$PHP_IMAGE" \
    php artisan podman:setup "${ARTISAN_ARGS[@]}"

shopt -s nullglob
QUADLET_FILES=("${PUBLISH_PATH}"/*/*.quadlets)
shopt -u nullglob

if [ ${#QUADLET_FILES[@]} -eq 0 ]; then
    echo "No rendered Quadlet units found in '${PUBLISH_PATH}'." >&2

    exit 1
fi

echo

if [ "$INSTALL" -eq 1 ] && [ "$SECRETS" -eq 1 ]; then
    echo "Installing each rendered service and setting its secrets..."
    echo
elif [ "$INSTALL" -eq 1 ]; then
    echo "Installing each rendered service..."
    echo
else
    echo "Rendered. Install each service with podman, e.g.:"
    echo
fi

for FILE in "${QUADLET_FILES[@]}"; do
    case "$FILE" in
        /*) ABS_FILE="$FILE" ;;
        *) ABS_FILE="${PWD}/${FILE}" ;;
    esac

    echo "  podman quadlet install \"${ABS_FILE}\" --replace"

    if [ "$INSTALL" -eq 1 ]; then
        "${LPOD_PODMAN_BINARY:-podman}" quadlet install "${ABS_FILE}" --replace
    fi

    if [ "$SECRETS" -eq 1 ]; then
        # A rendered ".quadlets" file can bundle several units (build,
        # container, volumes, network — see "app.quadlets"), each under its
        # own "# FileName=..." line, separated by "---". Only the
        # "[Container]" ones can have "Secret=" directives, so only those
        # get passed to "lpod SERVICE secrets"...
        CONTAINER_NAMES=()
        CURRENT_NAME=""
        HAS_CONTAINER=0

        flush_container_name() {
            if [ -n "$CURRENT_NAME" ] && [ "$HAS_CONTAINER" -eq 1 ]; then
                CONTAINER_NAMES+=("$CURRENT_NAME")
            fi

            CURRENT_NAME=""
            HAS_CONTAINER=0
        }

        while IFS= read -r LINE; do
            case "$LINE" in
                ---) flush_container_name ;;
                '# FileName='*) CURRENT_NAME="${LINE#\# FileName=}" ;;
                '[Container]') HAS_CONTAINER=1 ;;
            esac
        done < "$ABS_FILE"
        flush_container_name

        for NAME in "${CONTAINER_NAMES[@]}"; do
            "$LPOD_BINARY" "$NAME" secrets
        done
    fi
done
