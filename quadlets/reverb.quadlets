# FileName={{application}}-reverb
[Unit]
Description=Laravel Reverb container
After={{application}}.container
BindsTo={{application}}.container

[Container]
Image={{application}}.build
AutoUpdate=local
Environment=APP_COMMAND="php -d variables_order=EGPCS /app/artisan reverb:start"
UserNS=keep-id
ShmSize=128m
Secret={{application}}-env,target=/config/app.env,mode=0400,uid={{app-uid}},gid={{app-gid}}
Volume={{application}}-cache:/cache:rw,z
Network={{application}}.network
PublishPort=6001:6001

[Service]
Restart=always
RestartSec=5
TimeoutStartSec=120
TimeoutStopSec=60
