FROM docker.io/dunglas/frankenphp:latest AS base

ARG UID=1000
ARG GID=1000
ARG TZ=UTC
ARG NODE_VERSION=24
ARG POSTGRES_VERSION=18

WORKDIR /app

ENV DEBIAN_FRONTEND=noninteractive
ENV TZ=${TZ}
ENV PNPM_HOME="/pnpm"
ENV PATH="${PATH}:${PNPM_HOME}"
ENV PHP_CLI="php -d variables_order=EGPCS"
ENV FRANKEN_CLI="frankenphp php-cli"
ENV ARTISAN="${FRANKEN_CLI} /app/artisan"
ENV OCTANE="${FRANKEN_CLI} /app/artisan octane:frankenphp --host=0.0.0.0 --port=8000"

# Set timezone
RUN ln -snf /usr/share/zoneinfo/${TZ} /etc/localtime && echo ${TZ} > /etc/timezone

# Enable non-free and non-free-firmware repositories (for Intel VA drivers)
RUN sed -i 's/main/main non-free non-free-firmware/g' /etc/apt/sources.list.d/debian.sources

# Main dependencies
RUN apt-get update \
    && apt-get install -y --no-install-recommends \
    ca-certificates libcap2-bin curl unzip awscli \
    python3 python3-venv python3-pip gpg gnupg \
    mesa-va-drivers mesa-vulkan-drivers \
    libva2 libva-drm2 libmfx-gen1.2 libvpl2 \
    intel-media-va-driver-non-free \
    libavif-bin jpegoptim optipng pngquant gifsicle \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/*

# Create non-root user
RUN groupadd -g ${GID} docker \
    && useradd -u ${UID} -g docker -d /home/docker -s /bin/bash -m docker

# Create pnpm home directory
RUN mkdir -p ${PNPM_HOME} \
    && chown -R docker:docker ${PNPM_HOME}

# Add PostgreSQL APT repository and install client
RUN mkdir -p /etc/apt/keyrings \
    && curl -fsSL https://www.postgresql.org/media/keys/ACCC4CF8.asc | gpg --dearmor -o /etc/apt/keyrings/postgresql.gpg \
    && CODENAME=$(. /etc/os-release && echo "$VERSION_CODENAME") \
    && echo "deb [signed-by=/etc/apt/keyrings/postgresql.gpg] https://apt.postgresql.org/pub/repos/apt ${CODENAME}-pgdg main" | tee /etc/apt/sources.list.d/pgdg.list \
    && apt-get update \
    && apt-get install -y --no-install-recommends postgresql-client-${POSTGRES_VERSION} \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/*

# Add NodeSource APT repository and install Node.js
RUN mkdir -p /etc/apt/keyrings \
    && curl -fsSL https://deb.nodesource.com/gpgkey/nodesource-repo.gpg.key | gpg --dearmor -o /etc/apt/keyrings/nodesource.gpg \
    && echo "deb [signed-by=/etc/apt/keyrings/nodesource.gpg] https://deb.nodesource.com/node_${NODE_VERSION}.x nodistro main" | tee /etc/apt/sources.list.d/nodesource.list \
    && apt-get update \
    && apt-get install -y --no-install-recommends nodejs \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/*

# Create necessary directories
RUN mkdir -p /app /config /data /cache /media /import \
    && chown -R docker:docker /app /config /data /cache /media /import

# Build Shaka Streamer and set up Python environment
RUN python3 -m venv /opt/shaka-streamer-env \
    && /opt/shaka-streamer-env/bin/pip install --no-cache-dir shaka-streamer \
    && ln -s /opt/shaka-streamer-env/bin/shaka-streamer /usr/local/bin/shaka-streamer

# Copy FFmpeg, Shaka Packager, and ab-av1 from builder stage
COPY --from=builder /usr/local/bin/ffmpeg /usr/local/bin/ffmpeg
COPY --from=builder /usr/local/bin/ffprobe /usr/local/bin/ffprobe
COPY --from=builder /usr/local/bin/packager /usr/local/bin/packager
COPY --from=builder /usr/local/bin/ab-av1 /usr/local/bin/ab-av1

# PHP Configuration
RUN cp ${PHP_INI_DIR}/php.ini-production ${PHP_INI_DIR}/php.ini

# Install PHP extensions
RUN install-php-extensions @composer \
    apcu bcmath exif ffi gd \
    igbinary imagick inotify intl pcntl \
    pdo_pgsql redis sockets uv zip

# Custom PHP configuration
COPY containers/runtimes/php-production.ini /usr/local/etc/php/conf.d/xx-php-user.ini

# Node.js Configuration
RUN npm install -g npm@latest corepack@latest svgo@latest \
    && corepack enable && corepack prepare pnpm@latest --activate \
    && pnpm config set store-dir ${PNPM_HOME}/store

# Strip file capabilities from frankenphp
RUN setcap -r /usr/local/bin/frankenphp

# Entrypoint
COPY --chmod=755 containers/runtimes/entrypoint.sh /usr/local/bin/entrypoint.sh

# Clean up unnecessary files and caches to reduce image size
RUN apt-get clean && apt-get autoremove -y \
    && rm -rf /var/lib/apt/lists/* /tmp/* /var/tmp/* /root/.npm /root/.config

ENTRYPOINT ["/usr/local/bin/entrypoint.sh"]

FROM base AS production

WORKDIR /app

# Copy application source
COPY --chown=docker:docker . /app

# Switch to non-root user
USER docker

# Make sure an .env file exists
RUN cp .env.example .env

# Install PHP dependencies
RUN --mount=type=cache,target=/home/docker/.composer/cache,uid=${UID},gid=${GID} \
    composer install --prefer-dist --no-dev --optimize-autoloader --no-interaction --no-scripts

# Install Node.js dependencies
RUN --mount=type=cache,target=/pnpm/store,uid=${UID},gid=${GID} \
    pnpm install --frozen-lockfile

# Complete composer setup and build assets
RUN composer dump-autoload --optimize \
    && pnpm build && pnpm build:ssr && pnpm prune --prod

EXPOSE 6001 8000 13714

FROM base AS development

WORKDIR /app

# Set watch on development
ENV OCTANE="${OCTANE} --watch"

# Install development dependencies
RUN apt-get update \
    && apt-get install -y --no-install-recommends \
    nano git openssh-client \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/*

# PHP Configuration
RUN cp ${PHP_INI_DIR}/php.ini-development ${PHP_INI_DIR}/php.ini

# Custom PHP configuration for development
COPY containers/runtimes/php-development.ini /usr/local/etc/php/conf.d/xx-php-user.ini

# Set proper ownership
RUN chown -R docker:docker /app /pnpm

USER docker

EXPOSE 5173 6001 8000 13714
