{
    "name": "laravel-podman-devcontainer",
    "remoteUser": "docker",
    "containerUser": "docker",
    "containerEnv": {
        "HOME": "/home/docker",
    },
    "runArgs": ["--security-opt=label=disable", "--network=systemd-stry", "--userns=keep-id", "--init"],
    "mounts": ["source=${localEnv:HOME}/.ssh,target=/home/docker/.ssh,type=bind,ro=true"],
    "build": {
        "context": "./../",
        "dockerfile": "./../podman/frankenphp-octane/runtimes/Containerfile",
        "args": {
            "UID": "1000", // Replace with your desired UID (id -u)
            "GID": "1000" // Replace with your desired GID (id -g)
        }
    }
}
