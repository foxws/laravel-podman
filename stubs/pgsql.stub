# FileName=laravel-pgsql
[Unit]
Description=PostgreSQL container

[Container]
Image=docker.io/library/postgres:latest
AutoUpdate=registry
EnvironmentFile=./%n/laravel.env
ShmSize=512m
Volume=laravel-pgsql:/var/lib/postgresql:rw,Z,U
Network=laravel.network
ExposeHostPort=5432

[Service]
Restart=always
RestartSec=5
TimeoutStartSec=120
TimeoutStopSec=60
---
# FileName=laravel-pgsql-volume
[Volume]
Label=laravel-pgsql
